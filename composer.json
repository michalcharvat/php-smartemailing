{
    "name": "michalcharvat/php-smartemailing",
    "description": "Smart Emailing API v3 client for PHP (maintained fork of keltuo/php-smartemailing)",
    "version": "1.1.0",
    "type": "library",
    "license": "MIT",
    "keywords": ["smart emailing", "smart", "emailing", "api", "php", "client"],
    "authors": [
        {
            "name": "Lukas Paiskr",
            "email": "lukas@pasysdev.cz"
        },
        {
            "name": "Michal Charvat",
            "email": "info@michalcharvat.cz"
        }
    ],
    "autoload": {
        "psr-4": {
            "SmartEmailing\\": "src/"
        }
    },
    "autoload-dev": {
      "psr-4": {
        "SmartEmailing\\Test\\": "tests/"
      }
    },
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.0",
        "ext-json": "*",
        "guzzlehttp/guzzle": ">=6.2"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.2.0",
        "phpunit/phpunit": "^9.5",
        "jetbrains/phpstorm-attributes": "^1.0",
        "squizlabs/php_codesniffer": "*",
        "slevomat/coding-standard": "^7.0"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
